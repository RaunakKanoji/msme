DATABASE_URL=
SETU_ENV=sandbox
# demo = in-app mock provider; setu = live Setu sandbox/production API
SETU_MODE=demo
# Live mode requires a durable store. For single-process local dev only, set this true to run live Setu against
# the in-memory store instead of provisioning a database (not production-safe).
SETU_PERSISTENCE_READY=false
SETU_ALLOW_EPHEMERAL_STORE=false
SETU_CLIENT_ID=
SETU_CLIENT_SECRET=
SETU_PRODUCT_INSTANCE_ID=
# OAuth token host (POST /api/v2/auth/token). Defaults: sandbox https://uat.setu.co, production https://prod.setu.co
SETU_AUTH_BASE_URL=https://uat.setu.co
# AA FIU API host. Defaults: sandbox https://fiu-sandbox.setu.co, production https://fiu.setu.co
SETU_AA_BASE_URL=https://fiu-sandbox.setu.co
# Optional AA handle appended to the VUA (e.g. onemoney -> 9999999999@onemoney); leave blank to let the webview discover
SETU_AA_HANDLE=
SETU_REDIRECT_URL=http://localhost:3000/api/integrations/setu/callback
SETU_CONSENT_WEBHOOK_URL=
SETU_FI_WEBHOOK_URL=
SETU_PURPOSE_CODE=
SETU_PURPOSE_TEXT=
SETU_PURPOSE_REF_URI=
SETU_AUTO_FETCH_ENABLED=false
SETU_INSIGHTS_ENABLED=false
SETU_INSIGHTS_BASE_URL=
SETU_INSIGHTS_CLIENT_ID=
SETU_INSIGHTS_CLIENT_SECRET=
SETU_INSIGHTS_PRODUCT_INSTANCE_ID=
SETU_INSIGHTS_TEMPLATE_ID=
FINANCIAL_DATA_ENCRYPTION_KEY=
SETU_WEBHOOK_VERIFICATION_SECRET=
# Optional: RS256 public key (PEM) to verify Setu's detached x-jws-signature on webhooks; falls back to the shared secret
SETU_WEBHOOK_JWS_PUBLIC_KEY=

# ── Financial-data provider (Track 03) ──────────────────────────────
# Mode: auto (try Setu → cache → mock) | setu (strict) | mock (always demo)
FINANCIAL_DATA_PROVIDER=auto
# Fall back to cache/mock when the live provider is unavailable
FINANCIAL_DATA_FALLBACK_ENABLED=true
# Fallback scenario: stable-business | healthy-growth | cash-flow-stress | high-debt | seasonal-business | incomplete-data
FINANCIAL_DATA_MOCK_SCENARIO=stable-business
# Allow ?scenario= override outside production only (demo environments)
FINANCIAL_DATA_ALLOW_SCENARIO_OVERRIDE=false
# Setu request behaviour
SETU_REQUEST_TIMEOUT_MS=10000
SETU_MAX_RETRIES=1
